# Environment Variables
# NEVER commit secrets
# ========================
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local

# ========================
# Build Outputs
# ========================
dist/
build/
.next/
frontend/dist/
backend/dist/

# ========================
# Prisma
# (client is regenerated at build time)
# ========================
